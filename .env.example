# OpenRouter — get a key at https://openrouter.ai/keys (free models supported)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Free model router (auto-picks a free model). Override if needed.
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# Your public site URL (for OpenRouter attribution)
SITE_URL=http://localhost:3456

# Admin dashboard password — set something strong
ADMIN_SECRET=change-me-to-a-long-random-string

# Optional — persistent data directory (use a Railway volume in production)
# DATA_DIR=/data
