{
  "$schema": "https://opencode.ai/config.json",
  // Atlas project — free models only (saves paid GLM/Modal credits)
  "model": "opencode/deepseek-v4-flash-free",
  "small_model": "opencode/north-mini-code-free",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local + cloud)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "nemotron-3-ultra:cloud": {
          "name": "Nemotron 3 Ultra (cloud)",
          "limit": { "context": 262144, "output": 8192 }
        },
        "qwen3:4b": {
          "name": "Qwen3 4B (local)",
          "limit": { "context": 262144, "output": 8192 }
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen2.5 Coder 14B (local)",
          "limit": { "context": 32768, "output": 8192 }
        }
      }
    }
  },
  // Per-task model hints (used by scripts/run-opencode.sh)
  // implement → mimo-v2.5-free | analyze → deepseek-v4-flash-free | synthesize → ollama/nemotron-3-ultra:cloud
  "agent": {
    "build": {
      "model": "opencode/mimo-v2.5-free"
    }
  }
}
